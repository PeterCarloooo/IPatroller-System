{
  "rewrites": [
    { "source": "/login", "destination": "/" },
    { "source": "/signup", "destination": "/" },
    { "source": "/dashboard", "destination": "/" },
    { "source": "/ipatroller", "destination": "/" },
    { "source": "/command-center", "destination": "/" },
    { "source": "/illegals", "destination": "/" },
    { "source": "/report", "destination": "/" },
    { "source": "/setup", "destination": "/" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "routes": [
    {
      "src": "/[^.]+",
      "dest": "/",
      "status": 200
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
} 